# Drupal
web/core/
web/modules/contrib/
web/themes/contrib/
web/vendor/

# Composer
vendor/

# DDEV
.ddev/.gitignore
.ddev/import.yaml
.ddev/.homeadditions/
.ddev/config.local.yaml

# Database dumps (committed; generate via bootstrap procedure in README)
# db/dump.sql.gz

# Drupal files directory — exclude contents but track demo-images/ and pagefind index
web/sites/default/files/*
!web/sites/default/files/demo-images/
!web/sites/default/files/scolta-pagefind/
web/sites/default/files/scolta-pagefind/*
!web/sites/default/files/scolta-pagefind/pagefind/
# Exclude generated pagefind index fragments (rebuilt by post-start hook)
web/sites/default/files/scolta-pagefind/pagefind/fragment/
web/sites/default/files/scolta-pagefind/pagefind/index/
web/sites/default/files/scolta-pagefind/pagefind/*.pf_meta
web/sites/default/files/scolta-pagefind/pagefind/*.pf_index
web/sites/default/settings.local.php

# Scolta private build cache (regenerated by ddev post-start hook)
web/sites/default/private/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Node (if needed for theme build)
node_modules/
/.editorconfig
/.gitattributes

# Scolta/Pagefind: generated by ddev post-start hook, not stored in git
pagefind-site/